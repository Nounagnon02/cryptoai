# ─── CryptoAI Environment Configuration ──────────────────────────

# Mode d'exécution
MODE=paper                          # paper | live | backtest

# API Keys — Échanges
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_API_PASSPHRASE=

BYBIT_API_KEY=
BYBIT_API_SECRET=

OKX_API_KEY=
OKX_API_SECRET=
OKX_API_PASSPHRASE=

KRAKEN_API_KEY=
KRAKEN_API_SECRET=

COINBASE_API_KEY=
COINBASE_API_SECRET=
COINBASE_API_PASSPHRASE=

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=cryptoai
POSTGRES_USER=cryptoai
POSTGRES_PASSWORD=changeme_in_prod
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}

# Security
JWT_SECRET=changeme_in_prod_min_32_chars_long
ENCRYPTION_KEY=
API_RATE_LIMIT=100
API_RATE_WINDOW=60

# Logging
LOG_LEVEL=INFO                      # DEBUG | INFO | WARN | ERROR
LOG_FORMAT=json                     # json | text
LOG_FILE=logs/cryptoai.log

# Trading Parameters (Paper mode)
PAPER_INITIAL_CAPITAL=100000        # USD
PAPER_MAX_POSITION_SIZE=0.25        # % du capital par position
PAPER_MAX_DAILY_LOSS=0.05           # % perte max par jour
PAPER_FEES_MAKER=0.001              # 0.1%
PAPER_FEES_TAKER=0.001              # 0.1%

# Telegram Alerting (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
